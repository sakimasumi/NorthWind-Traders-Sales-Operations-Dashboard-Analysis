	partition FiscalCalendar = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(DATE(2013, 7, 1), DATE(2015, 6, 30)),
				    "CalendarDate", [Date],
				    "FiscalYear", IF(MONTH([Date]) >= 7, YEAR([Date]) + 1, YEAR([Date])),
				    "FiscalMonthNum", IF(MONTH([Date]) >= 7, MONTH([Date]) - 6, MONTH([Date]) + 6),
				    "MonthName", FORMAT([Date], "MMM")
				)

	annotation PBI_Id = 9f1e0ed4e5d14a7fbb9d48d1c9492392

